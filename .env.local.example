# =========================================================
# Smart Mutu — Environment Variables
# Copy file ini menjadi `.env.local` lalu isi nilainya.
# .env.local TIDAK ikut ter-commit (lihat .gitignore).
# =========================================================

# Dari Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Dari Supabase → Settings → API → Publishable key (sb_publishable_...)
# AMAN dipakai di browser karena RLS sudah aktif.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# CATATAN: Secret key (sb_secret_...) JANGAN ditaruh di sini.
# Hanya dipakai nanti di server (service role), simpan terpisah & jangan pakai prefix NEXT_PUBLIC_.
